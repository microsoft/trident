# Source of truth for the pinned MIC build inputs.
#
# Sourced by:
#   - .pipelines/templates/stages/build_image/build-pinned-mic.yml
#   - tests/images/mic-azl4-patches/build-pinned-mic.sh
#
# Every value here can be overridden via an environment variable of the
# same name when running the script locally.
#
# Bump procedure:
#   1. Update MIC_PIN_SHA below.
#   2. Re-run tests/images/mic-azl4-patches/build-pinned-mic.sh to validate.
#   3. Drop any patch in this directory that's superseded by the new SHA.
#   4. Update README.md's "Patches" table.
#
# This file is intentionally plain `KEY=value` (no shell expansion) so it
# can be parsed by both bash (`source PINNED.env`) and Python.

# Upstream MIC repository. Trident does not maintain a fork — patches in
# this directory carry any local fixes against the pinned SHA below.
MIC_PIN_URL=https://github.com/microsoft/azurelinux-image-tools.git

# SHA on microsoft/azurelinux-image-tools `main` validated by Trident's
# AZL4 E2E run on 2026-05-22. This is the merge commit of upstream PR #698
# (Vince Perri's "Add Azure Linux 4.0 support"), which is the first SHA on
# upstream main with native AZL4 distro-handler support. Bump only after
# re-validating end-to-end.
MIC_PIN_SHA=c582ba91b284da59a6d82def97fea9ceda5f63e0

# Tag the locally-built MIC container is loaded as. The AZL4 image build
# template passes this via `--container` to MIC.
MIC_CONTAINER_TAG=imagecustomizer:azl4-pinned

# docker buildx release used by the MIC container build. Verified against
# the SHA-256 in the release's published `checksums.txt` to defeat tag-move
# attacks on the GitHub release. See build-pinned-mic.sh / .yml for the
# verification step.
BUILDX_VER=v0.18.0
